{
  "name": "kinweave",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Kinweave — persona-to-persona negotiation protocol: runnable spec + simulation",
  "scripts": {
    "sim": "tsx src/sim/run.ts",
    "relay": "tsx src/net/relay-server.ts",
    "build:web": "esbuild web/app.ts --bundle --format=esm --outfile=web/dist/app.js --external:ws",
    "start": "npm run build:web && tsx server/index.ts",
    "serve": "tsx server/index.ts",
    "mcp": "tsx mcp/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.21.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "fastify": "^5.10.0",
    "qrcode-generator": "^1.5.2",
    "zod": "^3.25.76"
  }
}
